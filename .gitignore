logs/*.log
__pycache__/
*.pyc

# Persistence Logic (Phase 4 Neural Layer)
# We ignore all databases EXCEPT for the signal history 
# which is required for bot intelligence across GitHub Action runs.
data/*.db
!data/signals.db

# Docker
docker/.docker-compose.lock

# OS Files
.DS_Store
Thumbs.db
